<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manulink Essential Web Calculator</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .table-container::-webkit-scrollbar { height: 8px; }
        .table-container::-webkit-scrollbar-track { background: #f1f5f9; }
        .table-container::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 p-4 md:p-8 min-h-screen">
    <div class="max-w-6xl mx-auto">
        <div class="mb-8 text-center md:text-left">
            <h1 class="text-3xl font-bold text-emerald-800 tracking-tight">Manulink Essential</h1>
            <p class="text-slate-500 mt-1">Investment-Linked Policy Projection Calculator</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            <!-- Left Column: Controls (Span 4) -->
            <div class="lg:col-span-4 bg-white p-6 rounded-2xl shadow-sm border border-slate-200 h-fit">
                <h2 class="text-lg font-semibold mb-5 border-b pb-2 text-slate-700">Client Details</h2>
                
                <div class="space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-600 mb-1">Entry Age</label>
                            <input type="number" id="entryAge" value="30" class="w-full border border-slate-300 p-2.5 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none transition-all">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-600 mb-1">Gender</label>
                            <select id="gender" class="w-full border border-slate-300 p-2.5 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none bg-white">
                                <option value="Male" selected>Male</option>
                                <option value="Female">Female</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-600 mb-1">Smoking Status</label>
                        <select id="smoking" class="w-full border border-slate-300 p-2.5 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none bg-white">
                            <option value="Non-Smoker">Non-Smoker</option>
                            <option value="Smoker">Smoker</option>
                        </select>
                    </div>

                    <h2 class="text-lg font-semibold mt-6 mb-3 border-b pb-2 text-slate-700">Policy Setup</h2>

                    <div>
                        <label class="block text-sm font-medium text-slate-600 mb-1">Annual Premium (RM)</label>
                        <input type="number" id="annualPremium" value="6000" class="w-full border border-slate-300 p-2.5 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none transition-all">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-600 mb-1">Basic Face Amount (RM)</label>
                        <input type="number" id="faceAmount" value="330000" class="w-full border border-slate-300 p-2.5 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none transition-all">
                    </div>

                    <!-- Multi CI Rider Toggle -->
                    <div class="pt-2">
                        <label class="flex items-center space-x-3 cursor-pointer mb-2">
                            <input type="checkbox" id="includeMultiCI" class="w-5 h-5 text-emerald-600 rounded border-slate-300 focus:ring-emerald-500">
                            <span class="text-sm font-semibold text-slate-700">Include Multi CI Rider</span>
                        </label>
                        <div id="multiCIOptions" class="transition-opacity duration-300 opacity-40 pointer-events-none">
                            <label class="block text-sm font-medium text-slate-600 mb-1">Multi CI Face Amount (RM)</label>
                            <input type="number" id="multiCIFaceAmount" value="100000" class="w-full border border-slate-300 p-2.5 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none bg-white transition-all">
                        </div>
                    </div>

                    <!-- MHSE Rider Toggle -->
                    <div class="pt-2">
                        <label class="flex items-center space-x-3 cursor-pointer mb-2">
                            <input type="checkbox" id="includeMHSE" checked class="w-5 h-5 text-emerald-600 rounded border-slate-300 focus:ring-emerald-500">
                            <span class="text-sm font-semibold text-slate-700">Include MHSE Medical Rider</span>
                        </label>
                        <div id="mhseOptions" class="transition-opacity duration-300">
                            <label class="block text-sm font-medium text-slate-600 mb-1">MHSE Deductible</label>
                            <select id="deductible" class="w-full border border-slate-300 p-2.5 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none bg-white">
                                <option value="500">RM 500</option>
                                <option value="1000">RM 1,000</option>
                                <option value="5000">RM 5,000</option>
                                <option value="10000">RM 10,000</option>
                            </select>
                        </div>
                    </div>

                    <button onclick="calculate()" class="w-full bg-emerald-600 text-white font-semibold py-3 mt-4 rounded-lg hover:bg-emerald-700 shadow-md transition-all active:transform active:scale-95">
                        Generate Projection
                    </button>
                </div>
            </div>

            <!-- Right Column: Results Table (Span 8) -->
            <div class="lg:col-span-8 bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-lg font-semibold text-slate-700">30-Year Projection</h2>
                </div>
                
                <div class="table-container overflow-x-auto rounded-xl border border-slate-200">
                    <table class="w-full text-left border-collapse whitespace-nowrap">
                        <thead>
                            <tr class="bg-slate-50 text-slate-600 text-sm border-b border-slate-200">
                                <th class="p-4 font-semibold text-center">Age</th>
                                <th class="p-4 font-semibold text-right">Basic COI</th>
                                <th id="multiCIHeader" class="p-4 font-semibold text-right hidden">Multi CI Cost</th>
                                <th id="mhseHeader" class="p-4 font-semibold text-right">MHSE Cost</th>
                                <th class="p-4 font-semibold text-right text-emerald-800">Account Value</th>
                            </tr>
                        </thead>
                        <tbody id="resultsBody" class="text-sm divide-y divide-slate-100">
                            <tr><td colspan="5" class="p-8 text-center text-slate-400">Enter details and click generate to view the projection.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script src="data.js"></script>
    <script src="calculator.js"></script>
    <script>
        // Toggle UI Logic
        document.getElementById('includeMHSE').addEventListener('change', function() {
            const opts = document.getElementById('mhseOptions');
            opts.style.opacity = this.checked ? '1' : '0.4';
            opts.style.pointerEvents = this.checked ? 'auto' : 'none';
        });

        document.getElementById('includeMultiCI').addEventListener('change', function() {
            const opts = document.getElementById('multiCIOptions');
            opts.style.opacity = this.checked ? '1' : '0.4';
            opts.style.pointerEvents = this.checked ? 'auto' : 'none';
        });
    </script>
</body>
</html>
