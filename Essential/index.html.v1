<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manulink Essential Web Calculator</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 p-4 md:p-8 font-sans">
    <div class="max-w-4xl mx-auto bg-white p-6 rounded-xl shadow-lg border border-slate-200">
        <h1 class="text-2xl font-bold mb-6 text-blue-900 border-b pb-4">Manulink Essential Projection</h1>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mb-6">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1">Entry Age</label>
                <input type="number" id="entryAge" value="51" class="w-full border border-slate-300 p-2 rounded focus:ring-2 focus:ring-blue-500 outline-none">
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1">Annual Premium (RM)</label>
                <input type="number" id="annualPremium" value="6000" class="w-full border border-slate-300 p-2 rounded focus:ring-2 focus:ring-blue-500 outline-none">
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1">Gender</label>
                <select id="gender" class="w-full border border-slate-300 p-2 rounded focus:ring-2 focus:ring-blue-500 outline-none">
                    <option value="Male">Male</option>
                    <option value="Female">Female</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1">Smoking Status</label>
                <select id="smoking" class="w-full border border-slate-300 p-2 rounded focus:ring-2 focus:ring-blue-500 outline-none">
                    <option value="Non-Smoker">Non-Smoker</option>
                    <option value="Smoker">Smoker</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1">MHSE Deductible</label>
                <select id="deductible" class="w-full border border-slate-300 p-2 rounded focus:ring-2 focus:ring-blue-500 outline-none">
                    <option value="500">RM 500</option>
                    <option value="1000">RM 1,000</option>
                    <option value="5000">RM 5,000</option>
                    <option value="10000">RM 10,000</option>
                </select>
            </div>
        </div>

        <button onclick="calculate()" class="w-full bg-blue-600 text-white font-bold py-3 rounded-lg hover:bg-blue-700 transition duration-200">
            Generate 30-Year Projection
        </button>

        <div class="mt-8 overflow-x-auto rounded-lg border border-slate-200">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-100 text-slate-700 text-sm">
                        <th class="p-3 border-b font-semibold text-center">Attained Age</th>
                        <th class="p-3 border-b font-semibold text-right">Nett Premium</th>
                        <th class="p-3 border-b font-semibold text-right">Basic COI</th>
                        <th class="p-3 border-b font-semibold text-right">MHSE (Net of NCD)</th>
                        <th class="p-3 border-b font-semibold text-right">Ending Balance</th>
                    </tr>
                </thead>
                <tbody id="resultsBody" class="text-sm">
                    <tr><td colspan="5" class="p-4 text-center text-slate-500 italic">Enter details and click calculate to view projection.</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Scripts loaded in order -->
    <script src="data.js"></script>
    <script src="calculator.js"></script>
</body>
</html>
